# Virtual Environments
.venv/
venv/
env/

# Operating System
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Python Cache & Compiled Files
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo

# Project-Specific (Large Artifacts & Data)
mlruns/                    # MLflow experiment tracking (regenerated per run)
artifacts/                 # Large model artifacts (excluded, keep in gitignore)
data/raw/                  # Raw dataset files (not tracked)
data/processed/            # Processed datasets (regenerated)

# Claude Code & Tools
.claude/                   # Claude memory/context (local only)

# Gradio & Web UI Cache
.gradio/                   # Gradio cache files
flagged/                   # Gradio flagged outputs
*.db                       # Temporary databases

# System Files
*.log                      # Log files
.env                       # Environment variables (DO NOT COMMIT)
